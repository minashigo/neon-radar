{
  "$schema": "./docs/config.schema.json",

  "_comment": "Neon Radar scoring rules. Copy to scoring_rules.json and edit.",

  "min_confidence": 0.0,

  "rules": [
    {
      "name": "ema_trend",
      "enabled": true,
      "weight": 0.25,
      "params": {
        "fast_period": 20,
        "slow_period": 50,
        "threshold_pct": 0.005
      }
    },
    {
      "name": "rsi_momentum",
      "enabled": true,
      "weight": 0.20,
      "params": {
        "period": 14,
        "bull_low": 51.0,
        "bull_high": 70.0,
        "bear_low": 30.0,
        "bear_high": 49.0
      }
    },
    {
      "name": "volume_confirmation",
      "enabled": true,
      "weight": 0.20,
      "params": {
        "period": 20,
        "strong_multiplier": 1.5,
        "weak_multiplier": 0.5
      }
    },
    {
      "name": "volatility_filter",
      "enabled": true,
      "weight": 0.20,
      "params": {
        "period": 14,
        "min_atr_pct": 0.003,
        "max_atr_pct": 0.05
      }
    },
    {
      "name": "funding_trend",
      "enabled": true,
      "weight": 0.15,
      "params": {
        "window_size": 5,
        "trend_threshold": 0.0001
      }
    },
    {
      "name": "funding_extreme",
      "enabled": true,
      "weight": 0.20,
      "params": {
        "extreme_threshold": 0.0005
      }
    },
    {
      "name": "oi_expansion",
      "enabled": true,
      "weight": 0.20,
      "params": {
        "window_size": 6,
        "oi_expansion_threshold": 0.02,
        "price_move_threshold": 0.005
      }
    },
    {
      "name": "oi_divergence",
      "enabled": true,
      "weight": 0.15,
      "params": {
        "window_size": 6,
        "oi_drop_threshold": -0.015,
        "price_move_threshold": 0.005
      }
    },
    {
      "name": "ls_crowded",
      "enabled": true,
      "weight": 0.15,
      "params": {
        "extreme_long_ratio": 2.5,
        "extreme_short_ratio": 0.6
      }
    },
    {
      "name": "taker_flow_imbalance",
      "enabled": true,
      "weight": 0.20,
      "params": {
        "window_size": 12,
        "imbalance_threshold": 0.15
      }
    },
    {
      "name": "liquidation_cascade",
      "enabled": true,
      "weight": 0.25,
      "params": {
        "window_size": 3,
        "cascade_threshold_usd": 5000000.0
      }
    }
  ]
}
